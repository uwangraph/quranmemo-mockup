                    color: #afafaf;
                    text-transform: uppercase;
                    letter-spacing: 1px;
                    margin-bottom: 10px;
                  "
                >
                  Analisis Bacaan
                </div>
                <div style="display: flex; flex-direction: column; gap: 8px">
                  <div style="display: flex; align-items: center; gap: 8px">
                    <div
                      style="
                        font-size: 12px;
                        font-weight: 700;
                        color: #3c3c3c;
                        width: 80px;
                        flex-shrink: 0;
                      "
                    >
                      Makhraj
                    </div>
                    <div
                      style="
                        flex: 1;
                        height: 10px;
                        background: #e5e5e5;
                        border-radius: 100px;
                        overflow: hidden;
                      "
                    >
                      <div
                        style="
                          width: 88%;
                          height: 100%;
                          background: #58cc02;
                          border-radius: 100px;
                        "
                      ></div>
                    </div>
                    <div
                      style="
                        font-size: 12px;
                        font-weight: 800;
                        color: #58cc02;
                        width: 32px;
                        text-align: right;
                      "
                    >
                      88%
                    </div>
                  </div>
                  <div style="display: flex; align-items: center; gap: 8px">
                    <div
                      style="
                        font-size: 12px;
                        font-weight: 700;
                        color: #3c3c3c;
                        width: 80px;
                        flex-shrink: 0;
                      "
                    >
                      Panjang
                    </div>
                    <div
                      style="
                        flex: 1;
                        height: 10px;
                        background: #e5e5e5;
                        border-radius: 100px;
