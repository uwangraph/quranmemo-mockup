                  font-family: serif;
                  direction: rtl;
                  line-height: 2.8;
                  color: #3c3c3c;
                "
              >
                إِنَّ الَّذِينَ يَخۡشَوۡنَ رَبَّهُم بِٱلۡغَيۡبِ لَهُم
                <input
                  class="blank-input"
                  id="fillin-input"
                  placeholder="___"
                  dir="rtl"
                  oninput="checkFillinReady()"
                />
                وَأَجۡرٞ كَبِيرٞ
              </div>
              <div
                id="fillin-hint"
