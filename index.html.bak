    <!-- /qm-app -->

    <script>
      /* ===================== ONBOARDING LOGIC ===================== */
      const questions = [
        {
          q: "Apa motivasi utamamu menghafal Al-Quran?",
          opts: [
            { t: "Sholat lebih khusyuk", i: "🕌" },
            { t: "Target khatam / sanad", i: "🎓" },
            { t: "Teladan keluarga", i: "👨‍👩‍👧‍👦" },
            { t: "Ketenangan hati", i: "🍃" },
          ],
        },
        {
          q: "Sejauh mana pengalamanmu menghafal?",
          opts: [
            { t: "Baru mulai dari nol", i: "🌱", action: "skip_placement" },
            { t: "Hafal surah pendek", i: "📖" },
            { t: "Hafal 1 - 3 Juz", i: "📚" },
            { t: "Hafal > 3 Juz", i: "🏆" },
          ],
        },
        {
          q: "Bagaimana kemampuan membaca (Tahsin) kamu?",
          opts: [
            { t: "Masih mengeja huruf", i: "🅰️" },
            { t: "Lancar tanpa tajwid", i: "🗣️" },
            { t: "Lancar & paham tajwid", i: "✨" },
            { t: "Sangat fasih / Qari", i: "💎" },
          ],
        },
        {
          q: "Berapa target waktu belajarmu per hari?",
          opts: [
            { t: "Santai (5 menit)", i: "☕" },
            { t: "Reguler (10 menit)", i: "⏰" },
            { t: "Fokus (15 menit)", i: "🎯" },
            { t: "Intensif (30+ menit)", i: "🔥" },
          ],
        },
        {
          q: "Kapan waktu favoritmu berinteraksi?",
          opts: [
            { t: "Ba'da Subuh / Pagi", i: "🌅" },
            { t: "Istirahat Siang", i: "☀️" },
            { t: "Sore Hari", i: "🌇" },
            { t: "Malam Sebelum Tidur", i: "🌙" },
          ],
        },
      ];

      let currentQ = 0;
      let selectedOpt = null;
      let specialAction = null;

      function renderQuestion() {
        const q = questions[currentQ];
        const container = document.getElementById("q-container");
        container.innerHTML = `
    <div style="font-size:13px;font-weight:800;color:#afafaf;margin-bottom:10px;text-transform:uppercase;">Langkah ${currentQ + 1} dari 5</div>
    <div style="font-size:22px;font-weight:900;color:#3c3c3c;margin-bottom:24px;">${q.q}</div>
    <div style="display:grid;grid-template-columns:1fr;gap:12px;">
      ${q.opts
        .map(
          (o, i) => `
        <button class="option-card" onclick="selectOnboarding(${i}, '${o.action || ""}')">
          <div style="font-size:24px;width:40px;text-align:center;">${o.i}</div>
          <div style="font-size:15px;font-weight:800;">${o.t}</div>
        </button>
      `,
        )
        .join("")}
    </div>
  `;
        document.getElementById("onboarding-prog").style.width =
          (currentQ + 1) * 20 + "%";
        // Reset button state
        const btn = document.getElementById("onboarding-next");
        btn.className = "btn-duo btn-disabled";
        selectedOpt = null;
        specialAction = null;
      }

      function selectOnboarding(idx, action) {
        document
          .querySelectorAll("#q-container .option-card")
          .forEach((el, i) => {
            el.className = i === idx ? "option-card selected" : "option-card";
          });
        selectedOpt = idx;
        specialAction = action;
        document.getElementById("onboarding-next").className =
          "btn-duo btn-green";
      }

      function nextQuestion() {
        if (selectedOpt === null) return;

        // Q2 (index 1): unless "Baru mulai" is chosen, show placement test
        if (currentQ === 1 && specialAction !== "skip_placement") {
          go("placement");
          return;
        }

        currentQ++;
        if (currentQ < questions.length) {
          renderQuestion();
        } else {
          go("learn");
        }
      }

      /* ===================== PLACEMENT LOGIC ===================== */
      function pickPlacement(el, correct) {
        document
          .querySelectorAll("#s-placement .option-card")
          .forEach((o) =>
            o.classList.remove(
              "selected",
              "selected-correct",
              "selected-wrong",
            ),
          );
        el.classList.add("selected");
        document.getElementById("placement-next").className =
          "btn-duo btn-green";
      }

      function finishPlacement() {
        alert(
          "MasyaAllah! Kamu ditempatkan di Jalur Lanjutan (Surat Al-Mulk).",
        );
        currentQ++; // advance past Q2
        if (currentQ < questions.length) {
          renderQuestion();
        }
        go("onboarding");
      }

      /* ===================== GUIDED TADABBUR LOGIC ===================== */
      const tadabburSteps = [
        {
          t: "Tilawah",
          d: "Baca ayat secara berulang dengan tartil.",
          i: "📖",
        },
        {
          t: "Tafsir",
          d: "Pahami makna dari Ibnu Katsir & As-Sa'di.",
          i: "📚",
        },
        { t: "Ulama", d: "Simak pendapat para ulama terdahulu.", i: "👳" },
        {
          t: "Aktual",
          d: "Hubungkan dengan kejadian nyata hari ini.",
          i: "🌐",
        },
        {
          t: "Personal",
          d: "Apa hubungannya dengan hidupmu saat ini?",
          i: "👤",
        },
        {
          t: "Prinsip",
          d: "Simpulkan menjadi satu kalimat powerful.",
          i: "✨",
        },
        { t: "Amal", d: "Tentukan satu aksi nyata hari ini.", i: "✅" },
      ];

      function renderTadabburStep(idx) {
        const step = tadabburSteps[idx];
        const container = document.getElementById("tadabbur-content");
        container.innerHTML = `
    <div style="padding-top:10px;">
      <div style="font-size:11px;font-weight:800;color:#afafaf;margin-bottom:6px;text-transform:uppercase;">Langkah ${idx + 1} dari 7: ${step.t}</div>
      <div style="background:#fff;border:2px solid #e5e5e5;border-bottom-width:4px;border-radius:20px;padding:24px;text-align:center;margin-bottom:20px;">
        <div style="font-size:48px;margin-bottom:16px;">${step.i}</div>
        <div style="font-size:20px;font-weight:900;color:#3c3c3c;margin-bottom:12px;">${step.t}</div>
        <div style="font-size:14px;font-weight:700;color:#afafaf;line-height:1.6;">${step.d}</div>
        ${idx === 4 ? `<textarea placeholder="Tulis refleksimu di sini..." style="width:100%;height:80px;border-radius:12px;border:2px solid #e5e5e5;padding:12px;margin-top:16px;font-family:inherit;outline:none;resize:none;"></textarea>` : ""}
        ${
          idx === 6
            ? `<div style="display:flex;flex-direction:column;gap:8px;margin-top:16px;">
          <button class="option-card" onclick="this.classList.toggle('selected')">Sedekah hari ini</button>
          <button class="option-card" onclick="this.classList.toggle('selected')">Sholat tepat waktu</button>
          <button class="option-card" onclick="this.classList.toggle('selected')">Berbuat baik ke ortu</button>
        </div>`
            : ""
        }
      </div>
      <div style="display:flex;gap:10px;">
        ${idx > 0 ? `<button class="btn-duo btn-outline" style="flex:1;" onclick="renderTadabburStep(${idx - 1})">KEMBALI</button>` : ""}
        <button class="btn-duo btn-green" style="flex:2;" onclick="${idx < 6 ? `renderTadabburStep(${idx + 1})` : `alert('Alhamdulillah! Tadabbur selesai.');go('learn')`}">${idx < 6 ? "LANJUT" : "SIMPAN AMAL"}</button>
      </div>
    </div>
  `;
      }

      /* ===================== LIVE MARKING LOGIC ===================== */
      function mark(el, type) {
        const classMap = {
          Lupa: "err-lupa",
          Tajwid: "err-tajwid",
          Makhraj: "err-makhraj",
        };
        const colorMap = {
          Lupa: "#cc0000",
          Tajwid: "#cc7000",
          Makhraj: "#0898dc",
        };
        el.className = "marking-word " + classMap[type];
        const log = document.getElementById("marking-log");
        // Clear placeholder
        if (
          log.children.length === 1 &&
          log.children[0].innerText.includes("Belum")
        ) {
          log.innerHTML = "";
        }
        const entry = document.createElement("div");
        entry.style.cssText = `background:#fff;border:1px solid #e5e5e5;padding:8px 12px;border-radius:10px;font-size:12px;font-weight:800;color:${colorMap[type]};display:flex;justify-content:space-between;align-items:center;`;
        entry.innerHTML = `<span>${type}: "${el.innerText}"</span><span style="cursor:pointer;" onclick="this.parentElement.remove()">✕</span>`;
        log.prepend(entry);
      }

      /* ===================== SCREEN SWITCHING ===================== */
      const screenLabels = {
        onboarding: "✨ Onboarding",
        learn: "🏠 Belajar",
        musyrif: "👳 Musyrif",
        livemarking: "👳 Musyrif",
        lesson: "📖 Hafalan",
        fillin: "✍️ Isi Ayat",
        voice: "🎙️ Ucapkan",
        dragdrop: "🔀 Susun Kata",
        result: "🏆 Hasil",
        murojaah: "🔄 Murojaah",
        league: "⚔️ Liga",
        streak: "🔥 Streak",
        tadabbur: "📚 Tadabbur",
        shop: "💎 Toko",
        profile: "👤 Profil",
      };

      function go(id) {
        // Hide all screens
        document
          .querySelectorAll(".screen")
          .forEach((s) => s.classList.remove("on"));
        const screen = document.getElementById("s-" + id);
        if (screen) screen.classList.add("on");

        // Update nav buttons
        document.querySelectorAll(".snb").forEach((btn) => {
          btn.classList.remove("active");
          if (btn.textContent.trim() === screenLabels[id])
            btn.classList.add("active");
        });

        // Screen-specific init
        if (id === "onboarding") {
          renderQuestion();
        }

        if (id === "learn") {
          setTimeout(() => {
            const t = document.getElementById("toast-home");
            if (t) {
              t.style.display = "flex";
              setTimeout(() => (t.style.display = "none"), 4000);
            }
          }, 600);
        }

        // Reset lesson state when entering lesson screen
        if (id === "lesson") {
          resetLesson();
        }

        // Reset voice state when entering voice screen
        if (id === "voice") {
          resetRecording();
        }

        // Reset dragdrop when entering
        if (id === "dragdrop") {
          clearWords();
        }

        // Reset fillin when entering
        if (id === "fillin") {
          const inp = document.getElementById("fillin-input");
          if (inp) {
            inp.value = "";
            inp.className = "blank-input";
          }
          const fb = document.getElementById("fillin-feedback");
          if (fb) fb.innerHTML = "";
          const btn = document.getElementById("fillin-btn");
          if (btn) {
            btn.className = "btn-duo btn-disabled";
            btn.textContent = "PERIKSA";
            btn.onclick = checkFillin;
          }
          const hint = document.getElementById("fillin-hint");
          if (hint) hint.style.color = "#afafaf";
        }
      }

      /* ===================== LESSON — PILIHAN GANDA ===================== */
      let chosen = null;

      function resetLesson() {
        chosen = null;
        const opts = document.querySelectorAll("#opts .option-card");
        opts.forEach((o) => (o.className = "option-card"));
        const fb = document.getElementById("feedback-area");
        if (fb) fb.innerHTML = "";
        const btn = document.getElementById("check-btn");
        if (btn) {
          btn.className = "btn-duo btn-disabled";
          btn.textContent = "PERIKSA";
          btn.onclick = checkAnswer;
        }
      }

      function pick(el, correct) {
        document
          .querySelectorAll("#opts .option-card")
          .forEach((o) => (o.className = "option-card"));
        el.classList.add("selected");
        chosen = correct;
        const btn = document.getElementById("check-btn");
        btn.className = "btn-duo btn-green";
      }

      function checkAnswer() {
        if (chosen === null) return;
        const fb = document.getElementById("feedback-area");
        const btn = document.getElementById("check-btn");

        document.querySelectorAll("#opts .option-card").forEach((o) => {
          if (o.classList.contains("selected")) {
            o.classList.remove("selected");
            o.classList.add(chosen ? "selected-correct" : "selected-wrong");
          }
        });

        if (chosen) {
          fb.innerHTML =
            '<div class="feedback-bar feedback-correct"><div style="font-size:14px;font-weight:800;color:#46a302;">✓ Benar! MasyaAllah! 🎉</div><div style="font-size:12px;font-weight:700;color:#46a302;margin-top:4px;">+10 XP diraih</div></div>';
          btn.className = "btn-duo btn-green";
          btn.textContent = "LANJUT";
          btn.onclick = () => go("fillin");
        } else {
          fb.innerHTML =
            '<div class="feedback-bar feedback-wrong"><div style="font-size:14px;font-weight:800;color:#cc0000;">✗ Hampir benar! ❤️ -1</div><div style="font-size:12px;font-weight:700;color:#cc0000;margin-top:4px;">Jawaban yang benar adalah B</div></div>';
          btn.style.cssText = "";
          btn.className = "btn-duo";
          btn.style.background = "#ff4b4b";
          btn.style.color = "#fff";
          btn.style.borderBottom = "4px solid #cc0000";
          btn.textContent = "COBA LAGI";
          btn.onclick = () => {
            document
              .querySelectorAll("#opts .option-card")
              .forEach((o) => (o.className = "option-card"));
            fb.innerHTML = "";
            chosen = null;
            btn.style.cssText = "";
            btn.className = "btn-duo btn-disabled";
            btn.textContent = "PERIKSA";
            btn.onclick = checkAnswer;
          };
        }
      }

      /* ===================== AUDIO PLAY TOGGLE ===================== */
      let isPlaying = false;
      let playTimer = null;

      function togglePlay() {
        isPlaying = !isPlaying;
        const ico = document.getElementById("play-icon");
        if (ico)
          ico.className = isPlaying
            ? "ti ti-player-pause"
            : "ti ti-player-play";
        clearTimeout(playTimer);
        if (isPlaying) {
          playTimer = setTimeout(() => {
            isPlaying = false;
            if (ico) ico.className = "ti ti-player-play";
          }, 3000);
        }
      }

      // Separate toggle for voice screen (doesn't interfere with lesson's play-icon)
      let isVoicePlaying = false;
      let voicePlayTimer = null;

      function toggleVoicePlay() {
        isVoicePlaying = !isVoicePlaying;
        const ico = document.getElementById("voice-play-icon");
        if (ico)
          ico.className = isVoicePlaying
            ? "ti ti-player-pause"
            : "ti ti-player-play";
        clearTimeout(voicePlayTimer);
        if (isVoicePlaying) {
          voicePlayTimer = setTimeout(() => {
            isVoicePlaying = false;
            if (ico) ico.className = "ti ti-player-play";
          }, 3000);
        }
      }

      /* ===================== FILL IN THE BLANK ===================== */
      function checkFillinReady() {
        const v = document.getElementById("fillin-input").value.trim();
        const btn = document.getElementById("fillin-btn");
        btn.className = v ? "btn-duo btn-green" : "btn-duo btn-disabled";
      }

      function fillWord(w) {
        const inp = document.getElementById("fillin-input");
        inp.value = w;
        inp.className = "blank-input";
        checkFillinReady();
      }

      function checkFillin() {
        const v = document.getElementById("fillin-input").value.trim();
        const correct = "مَّغۡفِرَةٞ";
        const inp = document.getElementById("fillin-input");
        const fb = document.getElementById("fillin-feedback");
        const btn = document.getElementById("fillin-btn");

        if (v === correct) {
          inp.classList.add("correct");
          inp.classList.remove("wrong");
          fb.innerHTML =
            '<div class="feedback-bar feedback-correct"><div style="font-size:14px;font-weight:800;color:#46a302;">✓ Benar! Artinya: Ampunan 🎉</div><div style="font-size:12px;font-weight:700;color:#46a302;margin-top:4px;">+10 XP diraih</div></div>';
          btn.className = "btn-duo btn-green";
          btn.textContent = "LANJUT";
          btn.onclick = () => go("voice");
        } else {
          inp.classList.add("wrong");
          inp.classList.remove("correct");
          fb.innerHTML =
            '<div class="feedback-bar feedback-wrong"><div style="font-size:14px;font-weight:800;color:#cc0000;">✗ Belum tepat ❤️ -1</div><div style="font-size:12px;font-weight:700;color:#cc0000;margin-top:4px;">Petunjuk: dimulai huruf م</div></div>';
          const hint = document.getElementById("fillin-hint");
          if (hint) hint.style.color = "#ff9600";
          setTimeout(() => {
            inp.classList.remove("wrong");
            inp.value = "";
            fb.innerHTML = "";
            btn.className = "btn-duo btn-disabled";
            btn.textContent = "PERIKSA";
            btn.onclick = checkFillin;
          }, 1500);
        }
      }

      /* ===================== VOICE / MIC ===================== */
      let recInterval = null;
      let recSec = 0;

      function startRecording() {
        document.getElementById("voice-state-idle").style.display = "none";
        document.getElementById("voice-state-recording").style.display = "flex";
        recSec = 0;
        clearInterval(recInterval);
        recInterval = setInterval(() => {
          recSec++;
          const m = Math.floor(recSec / 60);
          const s = String(recSec % 60).padStart(2, "0");
          const timer = document.getElementById("rec-timer");
          if (timer) timer.textContent = "Merekam... " + m + ":" + s;
          if (recSec >= 5) stopRecording();
        }, 1000);
      }

      function stopRecording() {
        clearInterval(recInterval);
        document.getElementById("voice-state-recording").style.display = "none";
        document.getElementById("voice-state-result").style.display = "flex";
        const nb = document.getElementById("voice-next");
        if (nb) nb.style.display = "block";
      }

      function resetRecording() {
        clearInterval(recInterval);
        recSec = 0;
        const idle = document.getElementById("voice-state-idle");
        const recording = document.getElementById("voice-state-recording");
        const result = document.getElementById("voice-state-result");
        const nb = document.getElementById("voice-next");
        if (idle) idle.style.display = "flex";
        if (recording) recording.style.display = "none";
        if (result) result.style.display = "none";
        if (nb) nb.style.display = "none";
      }

      /* ===================== DRAG DROP ===================== */
      let placed = [];

      function placeWord(el, word) {
        if (el.classList.contains("used")) return;
        el.classList.add("used");
        placed.push({ el, word });
        const dz = document.getElementById("drop-zone");
        // Remove placeholder
        const placeholder = dz.querySelector("span");
        if (placeholder) dz.removeChild(placeholder);
        const tok = document.createElement("span");
        tok.className = "word-token placed";
        tok.textContent = word;
        tok.onclick = () => removeWord(tok, el, word);
        dz.appendChild(tok);
      }

      function removeWord(tok, srcEl, word) {
        tok.remove();
        srcEl.classList.remove("used");
        placed = placed.filter((p) => p.word !== word || p.el !== srcEl);
        const dz = document.getElementById("drop-zone");
        if (!dz.children.length) {
          dz.innerHTML =
            '<span style="font-size:12px;color:#d1d1d1;align-self:center;padding:4px 8px;font-weight:700;">Ketuk kata untuk menaruh di sini</span>';
        }
      }

      function clearWords() {
        placed.forEach((p) => p.el.classList.remove("used"));
        placed = [];
        document.getElementById("drop-zone").innerHTML =
          '<span style="font-size:12px;color:#d1d1d1;align-self:center;padding:4px 8px;font-weight:700;">Ketuk kata untuk menaruh di sini</span>';
        const fb = document.getElementById("dd-feedback");
        if (fb) fb.innerHTML = "";
      }

      function checkDrag() {
        const correct = [
          "إِنَّ",
          "الَّذِينَ",
          "يَخۡشَوۡنَ",
          "رَبَّهُم",
          "بِٱلۡغَيۡبِ",
          "لَهُم",
          "مَّغۡفِرَةٞ",
        ];
        const ans = placed.map((p) => p.word);
        const ok = JSON.stringify(ans) === JSON.stringify(correct);
        const fb = document.getElementById("dd-feedback");
        if (ok) {
          fb.innerHTML =
            '<div class="feedback-bar feedback-correct" style="margin:10px 0 0;"><div style="font-size:14px;font-weight:800;color:#46a302;">✓ Sempurna! MasyaAllah! 🎉</div></div>';
          setTimeout(() => go("result"), 900);
        } else {
          fb.innerHTML =
            '<div class="feedback-bar feedback-wrong" style="margin:10px 0 0;"><div style="font-size:14px;font-weight:800;color:#cc0000;">✗ Urutan belum tepat, coba lagi</div></div>';
        }
      }

      /* ===================== CHART BARS (PROFILE) ===================== */
      function initChartBars() {
        document.querySelectorAll("[data-h]").forEach((bar) => {
          bar.style.height = parseInt(bar.dataset.h) * 0.6 + "px";
        });
      }

      /* ===================== INIT ===================== */
      window.addEventListener("DOMContentLoaded", () => {
        initChartBars();
        go("onboarding");
      });
    </script>
  </body>
</html>
