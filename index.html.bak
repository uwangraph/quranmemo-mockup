                  border: 2px solid #e5e5e5;
                  border-bottom: 3px solid #e5e5e5;
                  border-radius: 12px;
                  padding: 8px 14px;
                  cursor: pointer;
                  font-family: &quot;Nunito&quot;, sans-serif;
                  font-size: 12px;
                  font-weight: 800;
                  color: #1cb0f6;
                "
              >
                <i
                  class="ti ti-player-play"
                  id="voice-play-icon"
                  style="font-size: 16px"
                ></i>
                Dengar Contoh
              </button>
            </div>

            <!-- state: idle -->
            <div
              id="voice-state-idle"
              style="
                text-align: center;
                flex: 1;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                gap: 12px;
              "
            >
              <div class="waveform idle">
                <div class="wave-bar"></div>
                <div class="wave-bar"></div>
                <div class="wave-bar"></div>
                <div class="wave-bar"></div>
                <div class="wave-bar"></div>
                <div class="wave-bar"></div>
                <div class="wave-bar"></div>
              </div>
              <div class="mic-btn" onclick="startRecording()">
                <i
                  class="ti ti-microphone"
                  style="font-size: 36px; color: #fff"
                ></i>
              </div>
              <div style="font-size: 13px; font-weight: 700; color: #afafaf">
                Ketuk untuk merekam
              </div>
            </div>

            <!-- state: recording -->
            <div
              id="voice-state-recording"
              style="
                text-align: center;
                flex: 1;
                display: none;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                gap: 12px;
              "
            >
              <div class="waveform">
                <div class="wave-bar"></div>
                <div class="wave-bar"></div>
                <div class="wave-bar"></div>
                <div class="wave-bar"></div>
                <div class="wave-bar"></div>
                <div class="wave-bar"></div>
                <div class="wave-bar"></div>
              </div>
              <div
