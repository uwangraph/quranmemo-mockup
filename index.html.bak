              style="background: none; border: none; cursor: pointer"
            >
              <i class="ti ti-x" style="font-size: 20px; color: #afafaf"></i>
            </button>
            <div class="prog-bar-bg" style="flex: 1">
              <div class="prog-bar-fill" style="width: 35%"></div>
            </div>
            <div class="xp-pill">
              <i class="ti ti-bolt" style="font-size: 16px"></i> 20
            </div>
            <div class="hearts-pill" style="color: #1cb0f6">
              <i class="ti ti-bolt" style="font-size: 15px"></i> 3
            </div>
          </div>
          <div style="padding: 12px 16px 0">
            <div
              style="
                font-size: 11px;
                font-weight: 800;
                color: #afafaf;
                text-transform: uppercase;
                letter-spacing: 1px;
                margin-bottom: 10px;
              "
            >
              Pilihan Ganda Audio
            </div>
            <div
              style="
                background: #f7f7f7;
                border-radius: 16px;
                padding: 16px;
                text-align: center;
                margin-bottom: 16px;
              "
            >
              <div
                style="
                  font-size: 13px;
                  color: #afafaf;
                  font-weight: 700;
                  margin-bottom: 10px;
                "
              >
                Dengarkan, lalu pilih kelanjutan ayat yang benar
              </div>
              <div style="display: flex; justify-content: center">
                <button
                  id="play-btn"
                  onclick="togglePlay()"
                  style="
                    width: 64px;
                    height: 64px;
                    border-radius: 50%;
                    background: #1cb0f6;
                    border: 0 solid #0898dc;
                    border-bottom-width: 4px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    cursor: pointer;
                  "
                >
                  <i
                    class="ti ti-player-play"
                    style="font-size: 26px; color: #fff"
                    id="play-icon"
                  ></i>
                </button>
              </div>
              <div
                style="
                  font-size: 19px;
                  margin-top: 12px;
                  font-family: serif;
                  color: #3c3c3c;
                  line-height: 1.8;
                  direction: rtl;
                "
              >
                إِنَّ الَّذِينَ يَخۡشَوۡنَ...
              </div>
              <div
                style="
                  font-size: 11px;
                  color: #afafaf;
                  font-weight: 700;
                  margin-top: 4px;
                "
              >
                Al-Mulk: 12
              </div>
            </div>
            <div id="opts">
              <button class="option-card" onclick="pick(this, false)">
                <div class="opt-num">A</div>
                <span style="direction: rtl; text-align: right; flex: 1"
                  >رَبَّهُم بِٱلۡغَيۡبِ لَهُم مَّغۡفِرَةٞ</span
                >
              </button>
              <button class="option-card" onclick="pick(this, true)">
                <div class="opt-num">B</div>
                <span style="direction: rtl; text-align: right; flex: 1"
                  >رَبَّهُم بِٱلۡغَيۡبِ لَهُم مَّغۡفِرَةٞ وَأَجۡرٞ كَبِيرٞ</span
                >
              </button>
              <button class="option-card" onclick="pick(this, false)">
                <div class="opt-num">C</div>
                <span style="direction: rtl; text-align: right; flex: 1"
                  >رَبَّهُم سِرٗا وَعَلَانِيَةٗ</span
                >
              </button>
              <button class="option-card" onclick="pick(this, false)">
                <div class="opt-num">D</div>
                <span style="direction: rtl; text-align: right; flex: 1"
                  >رَبَّهُم لَهُم أَجۡرٞ غَيۡرُ مَمۡنُونٍ</span
                >
              </button>
            </div>
            <div id="feedback-area"></div>
          </div>
          <div style="flex: 1"></div>
          <div style="padding: 12px 16px 16px">
            <button
              id="check-btn"
              class="btn-duo btn-disabled"
              onclick="checkAnswer()"
            >
              PERIKSA
            </button>
          </div>
        </div>

