<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>QuranMemo — Mockup Lengkap</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        font-family: "Nunito", sans-serif;
        background: #f0f0f0;
        min-height: 100vh;
        padding: 20px 0 40px;
      }

      /* ===================== SCREEN NAV SWITCHER ===================== */
      .qm-app {
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      .snav {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        justify-content: center;
        margin-bottom: 14px;
      }
      .snb {
        font-family: "Nunito", sans-serif;
        font-size: 11px;
        font-weight: 800;
        padding: 6px 12px;
        border-radius: 20px;
        border: 2px solid #e5e5e5;
        background: #fff;
        cursor: pointer;
        color: #afafaf;
        transition: all 0.15s;
      }
      .snb.active {
        background: #58cc02;
        color: #fff;
        border-color: #58cc02;
      }

      /* ===================== PHONE FRAME ===================== */
      .phone {
        width: 340px;
        background: #fff;
        border-radius: 36px;
        border: 3px solid #d0d0d0;
        overflow: hidden;
        position: relative;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
      }
      .statusbar {
        background: #fff;
        padding: 10px 20px 6px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 11px;
        font-weight: 700;
        color: #afafaf;
      }
      .screen {
        display: none;
        flex-direction: column;
        min-height: 600px;
      }
      .screen.on {
        display: flex;
      }

      /* ===================== COLOR TOKENS ===================== */
      .duo-green {
        color: #58cc02;
      }
      .duo-blue {
        color: #1cb0f6;
      }
      .duo-red {
        color: #ff4b4b;
      }
      .duo-gold {
        color: #ffc800;
      }
      .duo-purple {
        color: #ce82ff;
      }
      .duo-gray {
        color: #afafaf;
      }

      /* ===================== BUTTONS ===================== */
      .btn-duo {
        display: block;
        width: 100%;
        padding: 14px;
        border-radius: 16px;
        font-family: "Nunito", sans-serif;
        font-size: 15px;
        font-weight: 800;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        border: none;
        cursor: pointer;
        text-align: center;
        transition: all 0.1s;
      }
      .btn-green {
        background: #58cc02;
        color: #fff;
        border-bottom: 4px solid #46a302;
      }
      .btn-green:active {
        border-bottom: 2px solid #46a302;
        transform: translateY(2px);
      }
      .btn-blue {
        background: #1cb0f6;
        color: #fff;
        border-bottom: 4px solid #0898dc;
      }
      .btn-blue:active {
        border-bottom: 2px solid #0898dc;
        transform: translateY(2px);
      }
      .btn-purple {
        background: #ce82ff;
        color: #fff;
        border-bottom: 4px solid #9c52e0;
      }
      .btn-outline {
        background: #fff;
        color: #1cb0f6;
        border: 2px solid #e5e5e5;
        border-bottom: 4px solid #e5e5e5;
      }
      .btn-outline-red {
        background: #fff;
        color: #ff4b4b;
        border: 2px solid #e5e5e5;
        border-bottom: 4px solid #e5e5e5;
      }
      .btn-disabled {
        background: #e5e5e5;
        color: #afafaf;
        border-bottom: 4px solid #ccc;
        cursor: not-allowed;
      }

      /* ===================== THEME OVERRIDES ===================== */
      /* Musyrif Theme (Darker Green) */
      .phone.theme-musyrif .btn-green {
        background: #23a100;
        border-bottom-color: #1a7a00;
      }
      .phone.theme-musyrif .prog-bar-fill {
        background: #23a100;
      }
      .phone.theme-musyrif .statusbar {
        background: #1a1a1a;
        color: #fff;
      }
      .phone.theme-musyrif .topbar {
        background: #1a1a1a;
        color: #fff;
      }
      
      /* Admin Theme (Indigo/Professional) */
      .phone.theme-admin .btn-green {
        background: #4f46e5;
        border-bottom-color: #3730a3;
      }
      .phone.theme-admin .prog-bar-fill {
        background: #4f46e5;
      }
      .phone.theme-admin .statusbar {
        background: #1e293b;
        color: #fff;
      }
      .phone.theme-admin .topbar {
        background: #1e293b;
        color: #fff;
      }

      /* ===================== TOP BAR ===================== */
      .topbar {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px 8px;
      }
      .streak-pill {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: 13px;
        font-weight: 800;
        color: #ff9600;
      }
      .xp-pill {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: 13px;
        font-weight: 800;
        color: #1cb0f6;
      }
      .hearts-pill {
        display: flex;
        align-items: center;
        gap: 3px;
        font-size: 13px;
        font-weight: 800;
        color: #ff4b4b;
      }
      .gems-pill {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: 13px;
        font-weight: 800;
        color: #ce82ff;
      }

      /* ===================== PROGRESS BAR ===================== */
      .prog-wrap {
        padding: 0 16px 10px;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .prog-bar-bg {
        flex: 1;
        height: 16px;
        background: #e5e5e5;
        border-radius: 100px;
        overflow: hidden;
      }
      .prog-bar-fill {
        height: 100%;
        background: #58cc02;
        border-radius: 100px;
        transition: width 0.4s;
      }

      /* ===================== ANSWER OPTIONS ===================== */
      .option-card {
        width: 100%;
        padding: 12px 14px;
        border-radius: 12px;
        border: 2px solid #e5e5e5;
        border-bottom: 4px solid #e5e5e5;
        background: #fff;
        font-family: "Nunito", sans-serif;
        font-size: 14px;
        font-weight: 700;
        color: #3c3c3c;
        cursor: pointer;
        text-align: left;
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 8px;
        transition: all 0.1s;
      }
      .option-card:active {
        border-bottom: 2px solid #e5e5e5;
        transform: translateY(2px);
      }
      .option-card.selected-correct {
        border-color: #58cc02;
        border-bottom-color: #46a302;
        background: #d7ffb2;
        color: #46a302;
      }
      .option-card.selected-wrong {
        border-color: #ff4b4b;
        border-bottom-color: #cc0000;
        background: #ffdfe0;
        color: #cc0000;
      }
      .option-card.selected {
        border-color: #1cb0f6;
        border-bottom-color: #0898dc;
        background: #ddf4ff;
        color: #0898dc;
      }
      .opt-num {
        width: 28px;
        height: 28px;
        border-radius: 8px;
        border: 2px solid #e5e5e5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 800;
        color: #afafaf;
        flex-shrink: 0;
      }

      /* ===================== WORD TOKENS ===================== */
      .word-token {
        display: inline-block;
        padding: 8px 12px;
        border-radius: 12px;
        border: 2px solid #e5e5e5;
        border-bottom: 3px solid #e5e5e5;
        background: #fff;
        font-family: "Nunito", sans-serif;
        font-size: 13px;
        font-weight: 700;
        color: #3c3c3c;
        cursor: pointer;
        margin: 4px;
        transition: all 0.1s;
      }
      .word-token.used {
        background: #f0f0f0;
        color: #ccc;
        border-color: #eee;
        cursor: default;
      }
      .word-token.placed {
        border-color: #1cb0f6;
        border-bottom-color: #0898dc;
        background: #ddf4ff;
        color: #1cb0f6;
      }
      .drop-zone {
        min-height: 52px;
        border-radius: 12px;
        border: 2px dashed #d1d1d1;
        padding: 8px;
        display: flex;
        flex-wrap: wrap;
        margin: 0 0 10px;
      }

      /* ===================== FEEDBACK BARS ===================== */
      .feedback-bar {
        padding: 16px;
        border-radius: 16px;
        margin: 10px 0 0;
      }
      .feedback-correct {
        background: #d7ffb2;
      }
      .feedback-wrong {
        background: #ffdfe0;
      }

      /* ===================== LEAGUE ===================== */
      .league-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 14px;
        border-radius: 12px;
        margin-bottom: 6px;
      }
      .league-row.me {
        background: #ddf4ff;
        border: 2px solid #1cb0f6;
      }
      .avatar-circle {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 800;
        flex-shrink: 0;
      }

      /* ===================== BOTTOM NAV ===================== */
      .bottom-nav {
        display: flex;
        background: #fff;
        border-top: 2px solid #e5e5e5;
        padding: 8px 0 4px;
        margin-top: auto;
      }
      .nav-item {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
        cursor: pointer;
        padding: 4px 0;
        border: none;
        background: none;
      }
      .nav-item i {
        font-size: 22px;
        color: #afafaf;
      }
      .nav-item.active i {
        color: #58cc02;
      }
      .nav-item span {
        font-size: 9px;
        font-weight: 700;
        color: #afafaf;
        font-family: "Nunito", sans-serif;
      }
      .nav-item.active span {
        color: #58cc02;
      }

      /* ===================== MODAL ===================== */
      .modal-bg {
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 600px;
      }
      .modal-card {
        background: #fff;
        border-radius: 24px;
        padding: 24px 20px;
        width: 280px;
        text-align: center;
      }

      /* ===================== SECTION LABELS ===================== */
      .section-label {
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #afafaf;
        padding: 0 16px;
        margin: 10px 0 6px;
      }

      /* ===================== SKILL TREE ===================== */
      .unit-header {
        margin: 0 16px 10px;
        border-radius: 14px;
        padding: 12px 14px;
      }
      .unit-circle {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        border-bottom: 4px solid rgba(0, 0, 0, 0.15);
        cursor: pointer;
        margin: 0 auto 8px;
        border-style: solid;
        border-width: 0 0 4px 0;
        transition: transform 0.1s;
      }
      .unit-circle:active {
        transform: scale(0.95);
      }
      .unit-circle.locked {
        background: #e5e5e5;
        border-color: #ccc;
        cursor: not-allowed;
      }
      .unit-connector {
        width: 4px;
        height: 20px;
        background: #e5e5e5;
        margin: 0 auto;
      }

      /* ===================== FILL IN THE BLANK ===================== */
      .blank-input {
        border: none;
        border-bottom: 3px solid #1cb0f6;
        background: transparent;
        font-family: "Nunito", sans-serif;
        font-size: 18px;
        font-weight: 700;
        color: #3c3c3c;
        text-align: center;
        width: 120px;
        outline: none;
        padding: 4px 8px;
        direction: rtl;
      }
      .blank-input::placeholder {
        color: #d1d1d1;
      }
      .blank-input.correct {
        border-bottom-color: #58cc02;
        color: #46a302;
      }
      .blank-input.wrong {
        border-bottom-color: #ff4b4b;
        color: #cc0000;
      }

      /* ===================== VOICE EXERCISE ===================== */
      .mic-btn {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: #ff4b4b;
        border: 0 solid #cc0000;
        border-bottom-width: 5px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.15s;
        margin: 0 auto;
      }
      .mic-btn:active {
        border-bottom-width: 2px;
        transform: translateY(3px);
      }
      .mic-btn.recording {
        background: #ff4b4b;
        animation: pulse 1s ease-in-out infinite;
      }
      @keyframes pulse {
        0%,
        100% {
          box-shadow: 0 0 0 0 rgba(255, 75, 75, 0.4);
        }
        50% {
          box-shadow: 0 0 0 16px rgba(255, 75, 75, 0);
        }
      }
      .waveform {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 3px;
        height: 40px;
        margin: 12px 0;
      }
      .wave-bar {
        width: 4px;
        border-radius: 4px;
        background: #1cb0f6;
        animation: wave 1.2s ease-in-out infinite;
      }
      .wave-bar:nth-child(1) {
        height: 16px;
        animation-delay: 0s;
      }
      .wave-bar:nth-child(2) {
        height: 28px;
        animation-delay: 0.1s;
      }
      .wave-bar:nth-child(3) {
        height: 36px;
        animation-delay: 0.2s;
      }
      .wave-bar:nth-child(4) {
        height: 24px;
        animation-delay: 0.3s;
      }
      .wave-bar:nth-child(5) {
        height: 40px;
        animation-delay: 0.4s;
      }
      .wave-bar:nth-child(6) {
        height: 28px;
        animation-delay: 0.5s;
      }
      .wave-bar:nth-child(7) {
        height: 16px;
        animation-delay: 0.6s;
      }
      @keyframes wave {
        0%,
        100% {
          transform: scaleY(0.5);
        }
        50% {
          transform: scaleY(1.2);
        }
      }
      .waveform.idle .wave-bar {
        animation: none;
        height: 4px;
      }

      /* ===================== PROFILE ===================== */
      .achievement-badge {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
      }
      .badge-icon {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        border-bottom: 3px solid rgba(0, 0, 0, 0.12);
      }
      .badge-locked .badge-icon {
        background: #e5e5e5;
        filter: grayscale(1);
        opacity: 0.6;
      }

      /* ===================== SHOP ===================== */
      .shop-item {
        background: #fff;
        border-radius: 14px;
        border: 2px solid #e5e5e5;
        border-bottom-width: 4px;
        padding: 14px;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .shop-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        flex-shrink: 0;
      }

      /* ===================== TADABBUR ===================== */
      .tadabbur-card {
        background: #fff;
        border-radius: 14px;
        border: 2px solid #e5e5e5;
        border-bottom-width: 4px;
        padding: 14px;
        margin-bottom: 10px;
        cursor: pointer;
        transition: transform 0.1s;
      }
      .tadabbur-card:active {
        transform: scale(0.98);
      }
      .topic-chip {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      /* ===================== NOTIFICATION / TOAST ===================== */
      .achievement-toast {
        position: absolute;
        top: 70px;
        left: 12px;
        right: 12px;
        background: #fff;
        border-radius: 16px;
        border: 2px solid #ffc800;
        padding: 12px 14px;
        display: flex;
        align-items: center;
        gap: 10px;
        z-index: 100;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
        animation: slideDown 0.4s ease-out;
      }
      @keyframes slideDown {
        from {
          opacity: 0;
          transform: translateY(-20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* ===================== SCROLLABLE INNER ===================== */
      .scroll-content {
        flex: 1;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
      }

      /* ===================== LIVE MARKING ===================== */
      .marking-word {
        cursor: pointer;
        border-radius: 4px;
        transition: all 0.1s;
        padding: 2px 4px;
      }
      .marking-word:hover {
        background: rgba(88, 204, 2, 0.1);
      }
      .marking-word.err-lupa {
        background: #ffdfe0;
        color: #cc0000;
        border-bottom: 2px solid #cc0000;
      }
      .marking-word.err-tajwid {
        background: #fff7e6;
        color: #cc7000;
        border-bottom: 2px solid #cc7000;
      }
      .marking-word.err-makhraj {
        background: #ddf4ff;
        color: #0898dc;
        border-bottom: 2px solid #0898dc;
      }

      @keyframes pulse-green {
        0% {
          box-shadow: 0 0 0 0 rgba(88, 204, 2, 0.4);
        }
        70% {
          box-shadow: 0 0 0 10px rgba(88, 204, 2, 0);
        }
        100% {
          box-shadow: 0 0 0 0 rgba(88, 204, 2, 0);
        }
      }
    </style>
  </head>
  <body>
    <div class="qm-app">
      <!-- Screen nav switcher -->
      <div class="snav">
        <div style="width: 100%; text-align: center; font-size: 10px; font-weight: 900; color: #afafaf; margin: 10px 0 5px; text-transform: uppercase; letter-spacing: 1px;">Category: User</div>
        <button class="snb" onclick="go('onboarding')">✨ Onboarding</button>
        <button class="snb" onclick="go('learn')">🏠 Belajar</button>
        <button class="snb" onclick="go('lesson')">📖 Hafalan</button>
        <button class="snb" onclick="go('tadabbur')">📚 Tadabbur</button>
        <button class="snb" onclick="go('profile')">👤 Profil</button>
        
        <div style="width: 100%; text-align: center; font-size: 10px; font-weight: 900; color: #afafaf; margin: 15px 0 5px; text-transform: uppercase; letter-spacing: 1px;">Category: Musyrif</div>
        <button class="snb" onclick="go('musyrif')">👳 Dashboard Musyrif</button>
        <button class="snb" onclick="go('livemarking')">🔴 Live Marking</button>
        
        <div style="width: 100%; text-align: center; font-size: 10px; font-weight: 900; color: #afafaf; margin: 15px 0 5px; text-transform: uppercase; letter-spacing: 1px;">Category: Admin Dashboard</div>
        <button class="snb" onclick="go('admin-users')">👥 Monitor User</button>
        <button class="snb" onclick="go('admin-musyrif')">👨‍🏫 Monitor Musyrif</button>
      </div>

      <div class="phone" id="phone-frame">
        <div class="statusbar">
          <span>9:41</span
          ><span style="display: flex; gap: 4px; align-items: center"
            ><i class="ti ti-wifi" style="font-size: 13px"></i
            ><i class="ti ti-battery" style="font-size: 13px"></i
          ></span>
        </div>

        <!-- ================================================================ -->
        <!-- SCREEN: ONBOARDING                                               -->
        <!-- ================================================================ -->
        <div id="s-onboarding" class="screen">
          <div class="topbar">
            <div class="prog-bar-bg" style="flex: 1">
              <div
                class="prog-bar-fill"
                id="onboarding-prog"
                style="width: 20%"
              ></div>
            </div>
          </div>
          <div
            style="
              padding: 20px 20px 0;
              flex: 1;
              display: flex;
              flex-direction: column;
            "
            id="q-container"
          ></div>
          <div style="padding: 16px 20px 20px" id="onboarding-footer">
            <button
              class="btn-duo btn-disabled"
              id="onboarding-next"
              onclick="nextQuestion()"
            >
              LANJUT
            </button>
          </div>
        </div>

        <!-- ================================================================ -->
        <!-- SCREEN: PLACEMENT TEST                                           -->
        <!-- ================================================================ -->
        <div id="s-placement" class="screen">
          <div class="topbar">
            <button
              onclick="go('onboarding')"
              style="background: none; border: none; cursor: pointer"
            >
              <i
                class="ti ti-arrow-left"
                style="font-size: 20px; color: #afafaf"
              ></i>
            </button>
            <div
              style="
                flex: 1;
                text-align: center;
                font-size: 14px;
                font-weight: 800;
                color: #3c3c3c;
              "
            >
              Tes Penempatan
            </div>
            <div style="width: 28px"></div>
          </div>
          <div
            style="
              padding: 20px 20px 0;
              flex: 1;
              display: flex;
              flex-direction: column;
              align-items: center;
              justify-content: center;
              text-align: center;
            "
          >
            <div style="font-size: 64px; margin-bottom: 16px">🎯</div>
            <div
              style="
                font-size: 20px;
                font-weight: 900;
                color: #3c3c3c;
                margin-bottom: 8px;
              "
            >
              Ukur Hafalanmu
            </div>
            <div
              style="
                font-size: 14px;
                font-weight: 700;
                color: #afafaf;
