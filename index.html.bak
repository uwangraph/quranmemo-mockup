                id="rec-timer"
              >
                Merekam... 0:00
              </div>
              <div class="mic-btn recording" onclick="stopRecording()">
                <i
                  class="ti ti-player-stop"
                  style="font-size: 32px; color: #fff"
                ></i>
              </div>
              <div style="font-size: 13px; font-weight: 700; color: #afafaf">
                Ketuk untuk berhenti
              </div>
            </div>

            <!-- state: result -->
            <div
              id="voice-state-result"
              style="
                text-align: center;
                flex: 1;
                display: none;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                gap: 10px;
