                flex-wrap: wrap;
                gap: 6px;
                margin-bottom: 14px;
              "
            >
              <button class="word-token" onclick="fillWord('مَّغۡفِرَةٞ')">
                مَّغۡفِرَةٞ
              </button>
              <button class="word-token" onclick="fillWord('رَحۡمَةٞ')">
                رَحۡمَةٞ
              </button>
              <button class="word-token" onclick="fillWord('نِعۡمَةٞ')">
                نِعۡمَةٞ
              </button>
              <button class="word-token" onclick="fillWord('جَنَّةٞ')">
                جَنَّةٞ
              </button>
            </div>
            <div id="fillin-feedback"></div>
          </div>
          <div style="flex: 1"></div>
          <div style="padding: 12px 16px 16px">
            <button
